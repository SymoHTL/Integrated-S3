      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "sum(\n  rate({__name__=~\"^integrateds3_http_request_count(?:_request)?(?:_total)?$\", job=~\"$job\", instance=~\"$instance\", integrateds3_operation=~\"$operation\", http_response_status_code=~\"5..\"}[$__rate_interval])\n) or vector(0)",
          "instant": false,
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP 5xx rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "95th percentile request latency from integrateds3.http.request.duration.",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
