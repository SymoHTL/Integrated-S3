          "editorMode": "code",
          "expr": "count(\n  max by (integrateds3_provider) (\n    {__name__=~\"^integrateds3_backend_health_status(?:_state)?$\", job=~\"$job\", instance=~\"$instance\"} == 0\n  )\n) or vector(0)",
          "instant": false,
