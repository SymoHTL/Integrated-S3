      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(\n  0.95,\n  sum by (le) (\n    rate({__name__=~\"^integrateds3_http_request_duration(?:_ms|_milliseconds)?_bucket$\", job=~\"$job\", instance=~\"$instance\", integrateds3_operation=~\"$operation\"}[$__rate_interval])\n  )\n) or vector(0)",
          "instant": false,
          "legendFormat": "",
          "range": true,
          "refId": "A"
        }
      ],
